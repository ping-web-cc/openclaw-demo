# OpenAI API Key — required for OpenAI TTS in pit-stop
# / OpenAI TTS 語音合成用，不設定則回退到瀏覽器 TTS
OPENAI_API_KEY=sk-...

# OpenClaw image version / OpenClaw 版本
OPENCLAW_VERSION=2026.3.12

# Cron dashboard password / Cron dashboard 登入密碼
CRON_DASHBOARD_PASSWORD=demo
CRON_DASHBOARD_SECRET_KEY=change-this-in-production

# Base directory where service repos are cloned
# / 各 service repo 的根目錄（預設 ~/projects）
# SERVICES_DIR=~/projects
